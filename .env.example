# Copy to .env and fill in. .env is gitignored — never commit real values.
# Only needed for MANUAL SMOKE TESTS and ACCEPTANCE TESTS (TF_ACC=1),
# which hit the real IDCloudHost API and BILL REAL MONEY. Unit tests need none of this.

# IDCloudHost API key — sent as the `apikey:` header on every request.
IDCLOUDHOST_API_KEY=

# Enable acceptance tests. Leave UNSET for normal `go test ./...` (unit only).
# TF_ACC=1

# Non-secret, but referenced by examples/terraform.tfvars — keep out of git anyway.
IDCLOUDHOST_BILLING_ACCOUNT_ID=
IDCLOUDHOST_DEFAULT_LOCATION=sgp01
